# Database
DATABASE_URL=postgresql+asyncpg://comment_manager:comment_manager@localhost:5432/comment_manager
DATABASE_URL_SYNC=postgresql://comment_manager:comment_manager@localhost:5432/comment_manager

# JWT
JWT_SECRET=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# AI - Chat (DeepSeek)
AI_CHAT_API_KEY=sk-your-deepseek-key
AI_CHAT_BASE_URL=https://api.deepseek.com
AI_CHAT_MODEL=deepseek-v4-flash

# AI - Chat 备用（主 provider 失败时自动切换；Key 留空则不启用备用）
# 推荐填入 DashScope Key（与 AI_EMBEDDING_API_KEY 相同）
AI_CHAT_BACKUP_API_KEY=
AI_CHAT_BACKUP_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_CHAT_BACKUP_MODEL=qwen-turbo

# AI - Embedding (Qwen / DashScope)
AI_EMBEDDING_API_KEY=sk-your-qwen-key
AI_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_EMBEDDING_MODEL=text-embedding-v3

# DingTalk
DINGTALK_WEBHOOK_URL=

# Crawler
CRAWLER_INTERVAL_MINUTES=120

# Proxy（访问 Steam 等海外接口，填代理地址如 http://127.0.0.1:7897，留空则不使用）
STEAM_PROXY=

# 小黑盒 Cookie（爬取游戏评价所需，游戏页面需要登录）
# 获取方式：登录 xiaoheihe.cn → 浏览器 DevTools Console → 输入 document.cookie → 复制粘贴到此处
XIAOHEIHE_COOKIE=

# Discord Bot Token（抓取 Discord 频道消息所需）
# 获取方式：https://discord.com/developers/applications → 选择应用 → Bot → Token
# 注意：需在 Developer Portal 开启 Message Content Intent，Bot 需加入目标服务器
DISCORD_BOT_TOKEN=

# QQ 群消息（NapCat / LagRange OneBot v11 HTTP API）
# 需要先在本机安装并运行 NapCat 或 LagRange，用 QQ 号登录
# QQ_NAPCAT_URL：NapCat/LagRange HTTP 监听地址，默认 http://127.0.0.1:3000
# QQ_ACCESS_TOKEN：NapCat/LagRange 配置的 access_token，未设置则留空
QQ_NAPCAT_URL=http://127.0.0.1:3000
QQ_ACCESS_TOKEN=
# @ 以下 QQ 号的群消息无条件入库，逗号分隔，可填多个运营者/管理员的 QQ 号
QQ_AT_ALWAYS_INCLUDE=
